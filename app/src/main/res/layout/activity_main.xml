<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    android:layoutDirection="rtl">

    <!-- Menu 3 points en haut, hauteur fixe et reservee, ne fait pas partie du flux pondere -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="@string/menu_select_city" />
    </FrameLayout>

    <!-- Bloc pondere qui occupe TOUT l'espace restant : chaque ligne a un poids fixe
         de sa hauteur totale, garantissant une exploitation complete de l'ecran sans
         vide et sans qu'aucune ligne ne deborde sur la suivante, quelle que soit la
         taille physique de l'ecran. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_screen"
        android:paddingEnd="@dimen/padding_screen">

        <!-- Ligne 1: date avec jour de semaine dd/mm/yyyy -->
        <TextView
            android:id="@+id/tvDateGreg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="9"
            android:textSize="@dimen/text_date_greg"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            tools:text="السبت 20/06/2026" />

        <!-- Ligne 2: date hijri. Clic -> toast chourouk -->
        <TextView
            android:id="@+id/tvDateHijri"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:textSize="@dimen/text_date_hijri"
            android:textColor="@color/accent_gold"
            android:textStyle="bold"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            tools:text="5 محرم 1448" />

        <!-- Ligne 3: horloge hh:mm:ss, la plus grande, garantie sur 1 seule ligne sans
             jamais etre coupee : hauteur fixe en poids + autoSize qui respecte cette
             hauteur (au lieu de wrap_content qui pouvait deborder de son propre cadre). -->
        <TextView
            android:id="@+id/tvClock"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="20"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="20sp"
            android:autoSizeMaxTextSize="90sp"
            android:autoSizeStepGranularity="1sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            tools:text="14:27:05" />

        <!-- Lignes 4-8: les 5 prieres, toutes visibles simultanement, poids egaux -->
        <LinearLayout
            android:id="@+id/rowFajr"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:orientation="vertical"
            android:gravity="center" />

        <LinearLayout
            android:id="@+id/rowDhohr"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:orientation="vertical"
            android:gravity="center" />

        <LinearLayout
            android:id="@+id/rowAsr"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:orientation="vertical"
            android:gravity="center" />

        <LinearLayout
            android:id="@+id/rowMaghreb"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:orientation="vertical"
            android:gravity="center" />

        <LinearLayout
            android:id="@+id/rowIsha"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="10"
            android:orientation="vertical"
            android:gravity="center" />

    </LinearLayout>

    <!-- Ligne 9: 3 boutons precedent / now (masque par defaut) / suivant, hauteur fixe -->
    <LinearLayout
        android:id="@+id/navRow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:layoutDirection="rtl"
        android:paddingStart="@dimen/padding_screen"
        android:paddingEnd="@dimen/padding_screen"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/nav_button_bg"
            android:gravity="center"
            android:text="@string/previous"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_nav_button" />

        <TextView
            android:id="@+id/btnNow"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/nav_button_bg"
            android:gravity="center"
            android:text="@string/today"
            android:textColor="@color/accent_gold"
            android:textStyle="bold"
            android:textSize="@dimen/text_nav_button"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/nav_button_bg"
            android:gravity="center"
            android:text="@string/next"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_nav_button" />

    </LinearLayout>

</LinearLayout>
