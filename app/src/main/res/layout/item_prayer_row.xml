<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:layoutDirection="ltr"
    android:orientation="horizontal"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Nom de la priere : non affiche en permanence (reste cache, utilise seulement pour le Toast au clic) -->
    <TextView
        android:id="@+id/tvPrayerName"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:text="الفجر" />

    <!-- Ecoule : 25% a gauche, rouge -->
    <TextView
        android:id="@+id/tvElapsed"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:gravity="center"
        android:textDirection="ltr"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeMaxTextSize="34sp"
        android:autoSizeStepGranularity="1sp"
        android:textSize="@dimen/text_elapsed_remaining"
        android:textColor="@color/elapsed_negative_color"
        tools:text="7" />

    <!-- Heure de la priere : 50% au centre, auto-ajustee a l'espace alloue -->
    <TextView
        android:id="@+id/tvPrayerTime"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="18sp"
        android:autoSizeMaxTextSize="50sp"
        android:autoSizeStepGranularity="1sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:textDirection="ltr"
        tools:text="04:52" />

    <!-- Reste : 25% a droite, vert -->
    <TextView
        android:id="@+id/tvRemaining"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:gravity="center"
        android:textDirection="ltr"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeMaxTextSize="34sp"
        android:autoSizeStepGranularity="1sp"
        android:textSize="@dimen/text_elapsed_remaining"
        android:textColor="@color/remaining_positive_color"
        tools:text="38" />

</LinearLayout>
