<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layoutDirection="rtl"
    android:gravity="center_vertical|center_horizontal"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Label de la priere : cache par defaut, revele au clic puis redisparait -->
    <TextView
        android:id="@+id/tvPrayerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_prayer_name"
        android:textColor="@color/accent_gold"
        android:gravity="center"
        android:layout_marginStart="8dp"
        android:visibility="invisible"
        tools:text="الفجر" />

    <!-- Heure + (ecoule ou reste) cote a cote sur la meme ligne -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layoutDirection="ltr"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvPrayerTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_prayer_time"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:gravity="center"
            tools:text="04:52" />

        <TextView
            android:id="@+id/tvElapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textSize="@dimen/text_elapsed_remaining"
            android:textColor="@color/elapsed_negative_color"
            android:fontFamily="monospace"
            android:gravity="center"
            android:visibility="gone"
            tools:text="5:15" />

        <TextView
            android:id="@+id/tvRemaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textSize="@dimen/text_elapsed_remaining"
            android:textColor="@color/remaining_positive_color"
            android:fontFamily="monospace"
            android:gravity="center"
            android:visibility="gone"
            tools:text="3:53" />

    </LinearLayout>

</LinearLayout>
