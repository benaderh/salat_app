<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Nom de la priere : non affiche en permanence (reste cache, utilise seulement pour le Toast au clic) -->
    <TextView
        android:id="@+id/tvPrayerName"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:text="الفجر" />

    <!-- Heure de la priere : pleine largeur, auto-ajustee a l'espace reellement alloue -->
    <TextView
        android:id="@+id/tvPrayerTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="18sp"
        android:autoSizeMaxTextSize="50sp"
        android:autoSizeStepGranularity="1sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        tools:text="04:52" />

    <!-- Ecoule : ancre au bord GAUCHE (start en LTR), rouge -->
    <TextView
        android:id="@+id/tvElapsed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/tvPrayerTime"
        android:layout_alignBottom="@id/tvPrayerTime"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_marginLeft="6dp"
        android:layout_marginStart="6dp"
        android:minWidth="40dp"
        android:gravity="center"
        android:textSize="@dimen/text_elapsed_remaining"
        android:textColor="@color/elapsed_negative_color"
        tools:text="7" />

    <!-- Reste : ancre au bord DROIT (end en LTR), vert -->
    <TextView
        android:id="@+id/tvRemaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/tvPrayerTime"
        android:layout_alignBottom="@id/tvPrayerTime"
        android:layout_alignParentRight="true"
        android:layout_alignParentEnd="true"
        android:layout_marginRight="6dp"
        android:layout_marginEnd="6dp"
        android:minWidth="40dp"
        android:gravity="center"
        android:textSize="@dimen/text_elapsed_remaining"
        android:textColor="@color/remaining_positive_color"
        tools:text="38" />

</RelativeLayout>
