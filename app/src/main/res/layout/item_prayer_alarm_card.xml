<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="@color/surface_dark"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <!-- Nom de la priere -->
    <TextView
        android:id="@+id/tvPrayerLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent_gold"
        android:textStyle="bold"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        tools:text="الفجر" />

    <!-- ══════════════════════════════════════════════════════════════
         SECTION 1 : تنبيه قبل الأذان
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/alarm_before_adhan"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/switchBefore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Details section 1 (visible quand switchBefore = ON) -->
    <LinearLayout
        android:id="@+id/sectionBeforeDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <!-- Ligne المدة avec boutons +/- -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/duration_label"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnBeforeMinusMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_bg"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvBeforeMinutes"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="15" />

            <TextView
                android:id="@+id/btnBeforePlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_bg"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/minutes_unit"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Selection audio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sound_label"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnBeforeSound"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/select_mp3"
                android:textSize="11sp"
                android:backgroundTint="@color/button_bg"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Barre volume -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔇"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekBarBeforeVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="80"
                android:progressTint="@color/accent_gold"
                android:thumbTint="@color/accent_gold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Separateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="8dp" />

    <!-- ══════════════════════════════════════════════════════════════
         SECTION 2 : تنبيه الأذان
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/alarm_adhan"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/switchAtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Details section 2 (visible quand switchAtTime = ON) -->
    <LinearLayout
        android:id="@+id/sectionAtTimeDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <!-- Selection audio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/sound_label"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnAtTimeSound"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/select_mp3"
                android:textSize="11sp"
                android:backgroundTint="@color/button_bg"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Barre volume -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔇"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekBarAtTimeVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="100"
                android:progressTint="@color/accent_gold"
                android:thumbTint="@color/accent_gold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Separateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginBottom="8dp" />

    <!-- ══════════════════════════════════════════════════════════════
         SECTION 3 : الوضع الصامت
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/silent_mode"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/switchSilent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Details section 3 (visible quand switchSilent = ON) -->
    <LinearLayout
        android:id="@+id/sectionSilentDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <!-- Ligne بدأ بعد الأذان بـ avec boutons +/- -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/silent_delay_label"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnSilentDelayMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_bg"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvSilentDelay"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="5" />

            <TextView
                android:id="@+id/btnSilentDelayPlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_bg"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/minutes_unit"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Ligne مدة الوضع الصامت avec boutons +/- -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/silent_duration_label"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnSilentDurationMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_bg"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvSilentDuration"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="30" />

            <TextView
                android:id="@+id/btnSilentDurationPlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/nav_button_bg"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/minutes_unit"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
