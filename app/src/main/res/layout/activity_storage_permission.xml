<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/storage_perm_title"
        android:textColor="@color/accent_gold"
        android:textStyle="bold"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/storage_perm_body"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnGrantStorage"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/battery_perm_grant"
        android:backgroundTint="@color/accent_gold"
        android:textColor="@color/background_dark"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSkipStorage"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/battery_perm_skip"
        android:backgroundTint="@color/button_bg"
        android:textColor="@color/text_secondary" />

</LinearLayout>
